# Notion Configuration
# Get your Notion page ID from the URL of your duplicated Notion database
# Example: https://notion.site/256d55b883778070ab14e9ca4b56f037?v=...
# The page ID is: 256d55b883778070ab14e9ca4b56f037
NOTION_PAGE=your_notion_page_id_here

# Optional: Token for revalidating pages (used for on-demand revalidation)
# You can generate a random string for security
TOKEN_FOR_REVALIDATE=your_secret_token_here

# ─── Site Configuration ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_TITLE=blog title
NEXT_PUBLIC_SITE_DESCRIPTION=blog description
NEXT_PUBLIC_SITE_LOCALE=ko
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SITE_LOGO=
NEXT_PUBLIC_SITE_BANNER=

# ─── Author ──────────────────────────────────────────────────────────
NEXT_PUBLIC_AUTHOR_LOCALE_NAME=Author Locale Name
NEXT_PUBLIC_AUTHOR_EN_NAME=Author En Name
NEXT_PUBLIC_AUTHOR_BIO=Write a brief introduction about yourself

# ─── Social Links ────────────────────────────────────────────────────
NEXT_PUBLIC_AUTHOR_EMAIL=your-email@example.com
NEXT_PUBLIC_AUTHOR_GITHUB=https://github.com/your-username
NEXT_PUBLIC_AUTHOR_RSS=
NEXT_PUBLIC_AUTHOR_LINKEDIN=
NEXT_PUBLIC_AUTHOR_TWITTER=

# ─── Giscus Comment System ───────────────────────────────────────────
# Get these values from https://giscus.app/
NEXT_PUBLIC_GISCUS_REPO=your-github-username/your-blog-repo-name
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=Comments
NEXT_PUBLIC_GISCUS_CATEGORY_ID=
